# Railway PostgreSQL
DATABASE_URL=postgresql://user:pass@host:port/dbname

# App
APP_SECRET=your_secret_here

# SMTP (email OTP) — use Gmail App Password or any SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# Twilio (phone OTP) — leave blank to use console log in dev
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=+1234567890
